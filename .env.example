# Supabase — required
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Sentry — optional (get DSN from sentry.io, free tier sufficient)
# Add as GitHub Secret: EXPO_PUBLIC_SENTRY_DSN
EXPO_PUBLIC_SENTRY_DSN=

# Environment — set automatically by CI (staging/production)
EXPO_PUBLIC_ENV=development
